<!DOCTYPE html>
<html>
<body>

<form onsubmit="return validate()">
Name:
<input type="text" id="name">
<input type="submit">
</form>

<script>
function validate()
{
    let name = document.getElementById("name").value;

    if(name == "")
    {
        alert("Name cannot be empty");
        return false;
    }

    return true;
}
</script>

</body>
</html>
